#include <stdio.h>
 
int fibonacci(int n) {
  	if (n == 0) return 0;
  	if (n == 1) return 1;
  	return fibonacci(n - 1) + fibonacci(n - 2);
}
 
int main() {
  	int n, i;
  	printf("25331A05G3\n");
  	printf("Enter number of terms: ");
  	scanf("%d", &n);
  	printf("Fibonacci Series: ");
  	for (i = 0; i < n; i++)
        	printf("%d ", fibonacci(i));
  	printf("\n");
  	return 0;
}
